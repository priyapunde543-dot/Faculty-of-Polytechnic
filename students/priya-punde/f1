def calculate(l,b,h):
    if(h>0):
        volume=l*b*h
        perimeter=4*(l+b+h)
        return(volume,perimeter)
    else:
            area=l*b
            perimeter=2*(l+b)
            return(area,perimeter)
print("cuboid:",calculate(2,7,9))
print("rectangle",calculate(1,2,6))


